      "settings": {
        "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .reviews-section {\n    background: #b82e38;\n    padding: 32px 16px;\n    width: 100%;\n    box-sizing: border-box;\n    font-family: 'Barlow', Arial, sans-serif;\n    text-align: center;\n  }\n\n  .reviews-stars-row {\n    display: flex;\n    justify-content: center;\n    gap: 8px;\n    margin-bottom: 12px;\n  }\n\n  .reviews-stars {\n    color: #e8a0b4;\n    font-size: 20px;\n  }\n\n  .reviews-title {\n    font-size: 28px;\n    font-weight: 900;\n    color: white;\n    text-transform: uppercase;\n    margin-bottom: 24px;\n  }\n\n  .reviews-tabs {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 10px;\n    justify-content: center;\n    margin-bottom: 28px;\n  }\n\n  .reviews-tab {\n    padding: 10px 20px;\n    border-radius: 50px;\n    border: 2px solid #ccc;\n    background: #fff;\n    font-size: 14px;\n    font-weight: 700;\n    cursor: pointer;\n  }\n\n  .reviews-tab.active {\n    background: #c0607a;\n    border-color: #c0607a;\n    color: #fff;\n  }\n\n  .reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 24px;\n    max-width: 1000px;\n    margin: 0 auto;\n  }\n\n  .review-card {\n    text-align: center;\n  }\n\n  .review-card-stars {\n    color: #e8a0b4;\n    font-size: 18px;\n  }\n\n  .review-card-text {\n    font-size: 14px;\n    color: #222;\n  }\n\n  .review-card-author {\n    font-weight: 700;\n    margin-top: 6px;\n  }\n\n  @media (max-width: 599px) {\n    .reviews-grid {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n\n<div class=\"reviews-section\">\n\n  <div class=\"reviews-stars-row\">\n    <span class=\"reviews-stars\">★★★★★</span>\n    <span>4.8 stars</span>\n  </div>\n\n  <h2 class=\"reviews-title\">Stand Straighter. Feel Better.</h2>\n\n  <div class=\"reviews-tabs\">\n    <button class=\"reviews-tab active\" onclick=\"switchTab('results', event)\">Results</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('comfort', event)\">Comfort</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('pain', event)\">Pain Relief</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('fit', event)\">Fit</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('repurchase', event)\">Would Buy Again</button>\n  </div>\n\n  <div class=\"reviews-grid\" id=\"reviews-grid\"></div>\n\n</div>\n\n<script>\n  const allReviews = {\n    results: [\n      { text: \"I noticed my posture improving within a few days. Huge difference!\", author: \"Ahmad K.\" },\n      { text: \"I stand straighter without even thinking about it now.\", author: \"Rami H.\" },\n      { text: \"People actually told me my posture looks better!\", author: \"Tarek M.\" },\n    ],\n    comfort: [\n      { text: \"Very comfortable, I can wear it for hours.\", author: \"Nour A.\" },\n      { text: \"Lightweight and doesn’t feel tight at all.\", author: \"Maya S.\" },\n      { text: \"Easy to wear under clothes without noticing it.\", author: \"Sara L.\" },\n    ],\n    pain: [\n      { text: \"My back pain is much less after using it daily.\", author: \"Karim N.\" },\n      { text: \"Helped reduce the tension in my shoulders.\", author: \"Fadi R.\" },\n      { text: \"I feel less discomfort after long hours at my desk.\", author: \"Hassan J.\" },\n    ],\n    fit: [\n      { text: \"Adjustable straps make it fit perfectly.\", author: \"Dina K.\" },\n      { text: \"Fits well and stays in place all day.\", author: \"Rana F.\" },\n      { text: \"Easy to adjust for different body types.\", author: \"Lina M.\" },\n    ],\n    repurchase: [\n      { text: \"Bought one for myself and another for my brother.\", author: \"Omar S.\" },\n      { text: \"Definitely worth it, I’d buy again.\", author: \"Ali T.\" },\n      { text: \"One of the best things I’ve ordered online.\", author: \"Youssef B.\" },\n    ]\n  };\n\n  function switchTab(tab, event) {\n    document.querySelectorAll('.reviews-tab').forEach(btn => btn.classList.remove('active'));\n    event.target.classList.add('active');\n\n    const reviews = allReviews[tab];\n\n    document.getElementById('reviews-grid').innerHTML = reviews.map(r => `\n      <div class=\"review-card\">\n        <div class=\"review-card-stars\">★★★★★</div>\n        <p class=\"review-card-text\">${r.text}</p>\n        <span class=\"review-card-author\">${r.author}</span>\n      </div>\n    `).join('');\n  }\n\n  switchTab('results', { target: document.querySelector('.reviews-tab') });\n</script>",
